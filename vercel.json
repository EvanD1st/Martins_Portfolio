{
    "builds": [
        {
            "src": "PORTFOLIO/wsgi.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
        },
        {
            "src": "my_portfolio/static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/my_portfolio/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "PORTFOLIO/wsgi.py"
        }
    ]
}
